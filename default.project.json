{
  "name": "CasinoEmpireTycoon",
  "tree": {
    "$className": "DataModel",

    "ReplicatedStorage": {
      "Shared": {
        "$path": "src/shared"
      },
      "Machines": {
        "$path": "assets/machines"
      }
    },

    "ServerScriptService": {
      "Server": {
        "$path": "src/server"
      }
    },

    "StarterPlayer": {
      "StarterPlayerScripts": {
        "Client": {
          "$path": "src/client"
        }
      }
    },

    "StarterGui": {
      "$path": "src/gui"
    },

    "Workspace": {
      "$properties": {
        "FilteringEnabled": true,
        "StreamingEnabled": false
      }
    },

    "ServerStorage": {
      "Assets": {
        "$path": "assets/models"
      }
    },

    "Lighting": {
      "$properties": {
        "Ambient": [0.05, 0.02, 0.08],
        "Brightness": 1.5,
        "GlobalShadows": true,
        "Outlines": false,
        "Technology": "Future",
        "FogEnd": 1000
      }
    },

    "SoundService": {
      "$properties": {
        "RespectFilteringEnabled": true
      }
    }
  }
}
